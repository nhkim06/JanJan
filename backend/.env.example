DJANGO_SECRET_KEY=change-me-in-local-env
DJANGO_DEBUG=True
DJANGO_ALLOWED_HOSTS=localhost,127.0.0.1
DJANGO_USE_SQLITE=False
CORS_ALLOWED_ORIGINS=http://localhost:5173,http://127.0.0.1:5173,https://jan-jan.vercel.app
CORS_ALLOWED_ORIGIN_REGEXES=^https://[a-z0-9-]+\.vercel\.app$
GOOGLE_OAUTH_CLIENT_ID=your-google-oauth-client-id.apps.googleusercontent.com
GOOGLE_OAUTH_CLIENT_SECRET=your-google-oauth-client-secret
# Production example: https://janjan-backend.vercel.app/auth/callback
GOOGLE_OAUTH_REDIRECT_URI=http://localhost:8000/auth/callback
# Production example: https://jan-jan.vercel.app/auth/callback
FRONTEND_AUTH_CALLBACK_URL=http://localhost:5173/auth/callback
GEMINI_API_KEY=your-gemini-api-key
GEMINI_MODEL=gemini-2.0-flash

# Supabase PostgreSQL
# Leave these blank to use local SQLite during early development.
SUPABASE_DB_NAME=postgres
SUPABASE_DB_USER=postgres.your-project-id
SUPABASE_DB_PASSWORD=your-supabase-db-password
SUPABASE_DB_HOST=aws-0-your-region.pooler.supabase.com
SUPABASE_DB_PORT=6543
